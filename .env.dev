# =============================================================================
# .env — Variables de entorno PRODUCCIÓN
# NUNCA commitear este archivo con valores reales al repositorio.
# Agregar .env a .gitignore.
# =============================================================================

NODE_ENV=production

# -----------------------------------------------------------------------------
# Credenciales PostgreSQL — usar contraseñas fuertes (mínimo 32 caracteres)
# Generar con: openssl rand -base64 32
# -----------------------------------------------------------------------------
DB_USERNAME=app_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE_32CHARS
DB_DATABASE=app_db

# Credenciales de replicación (internas entre nodos, nunca exponer)
DB_REPL_USER=replicator
DB_REPL_PASSWORD=CAMBIAR_POR_PASSWORD_REPL_FUERTE

# -----------------------------------------------------------------------------
# Conexión de la app → PgDog
# Dentro de Docker Compose: PGDOG_HOST=pgdog
# Desde el host o K8s externo: PGDOG_HOST=<IP o dominio>
# -----------------------------------------------------------------------------
PGDOG_HOST=pgdog
PGDOG_PORT=6432
PGDOG_USERNAME=app_user
PGDOG_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE_32CHARS
PGDOG_DATABASE=app_db

# -----------------------------------------------------------------------------
# Pool de TypeORM → PgDog (bajo: PgDog gestiona el pool real)
# Fórmula: DB_POOL_MAX × instancias_app = conexiones totales a PgDog
# -----------------------------------------------------------------------------
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# -----------------------------------------------------------------------------
# Configuración del pool de TypeORM
# IMPORTANTE: Mantener bajo porque PgDog gestiona las conexiones reales a PG
# El número efectivo de conexiones a PostgreSQL será:
#   DB_POOL_MAX (TypeORM) × número_de_instancias_de_la_app
# -----------------------------------------------------------------------------
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# -----------------------------------------------------------------------------
# Entorno de la aplicación
# -----------------------------------------------------------------------------
NODE_ENV=development
