# =============================================================================
# .env.example — PLANTILLA de variables de entorno
#
# ⚠ NUNCA commitear .env con credenciales reales.
# En Dokploy: configurar estas variables en la UI del stack (Environment Variables).
# Generar passwords con: openssl rand -base64 32
# =============================================================================

NODE_ENV=production

# PostgreSQL
DB_USERNAME=CAMBIAR_POR_USUARIO
DB_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE
DB_DATABASE=CAMBIAR_POR_NOMBRE_DB
DB_REPL_USER=CAMBIAR_POR_USUARIO_REPLICACION
DB_REPL_PASSWORD=CAMBIAR_POR_PASSWORD_REPLICACION

# Conexión app → PgDog
# Acceso externo vía Traefik TCP/SNI (puerto 443, sin exponer 6432)
# Desde otro servidor Dokploy: usar el dominio configurado en PGDOG_DOMAIN
PGDOG_HOST=db.tudominio.com    # = valor de PGDOG_DOMAIN, puerto 443
PGDOG_PORT=443
PGDOG_USERNAME=CAMBIAR_POR_USUARIO
PGDOG_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE
PGDOG_DATABASE=CAMBIAR_POR_NOMBRE_DB

# Dominio para el endpoint TCP de PgDog en Traefik (ej: db.tudominio.com)
# Traefik obtiene cert Let's Encrypt para este subdominio automáticamente
PGDOG_DOMAIN=db.tudominio.com

# Pool TypeORM
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000
