{
  "name": "pgdog-typeorm-test",
  "version": "1.0.0",
  "description": "Prueba de conexión TypeORM → PgDog → PostgreSQL HA",
  "main": "dist/app.module.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "test:local":  "ts-node src/index.ts",
    "migration:run":     "typeorm migration:run -d src/database/database.module.ts",
    "migration:revert":  "typeorm migration:revert -d src/database/database.module.ts",
    "migration:generate":"typeorm migration:generate -d src/database/database.module.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg":     "^8.12.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node":    "^10.9.2",
    "typescript": "^5.4.5"
  }
}
